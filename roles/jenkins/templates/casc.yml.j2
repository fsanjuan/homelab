jenkins:
  securityRealm:
    local:
      allowsSignup: false
      users:
        - id: "pellegrini"
          password: "{{ jenkins_admin_password }}"
  authorizationStrategy:
    loggedInUsersCanDoAnything:
      allowAnonymousRead: false

unclassified:
  location:
    url: "https://{{ meshnet_hostname }}/jenkins/"
